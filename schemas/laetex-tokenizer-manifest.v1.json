{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.nullxes.example/laetex-tokenizer-manifest.v1.json",
  "title": "LÆTEX tokenizer corpus manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "snapshot_id",
    "created_at",
    "training_allowed",
    "purpose",
    "sources",
    "normalization",
    "tokenizer"
  ],
  "properties": {
    "schema_version": {"const": "laetex.tokenizer.manifest/v1"},
    "snapshot_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "training_allowed": {"const": true},
    "purpose": {"enum": ["tokenizer_research", "synthetic_test"]},
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/source"}
    },
    "normalization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unicode", "line_endings", "encoding"],
      "properties": {
        "unicode": {"const": "identity"},
        "line_endings": {"const": "preserve"},
        "encoding": {"const": "utf-8-strict"}
      }
    },
    "tokenizer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "vocab_size", "byte_fallback", "special_tokens"],
      "properties": {
        "type": {"const": "byte_level_bpe"},
        "vocab_size": {"const": 128000},
        "byte_fallback": {"const": true},
        "special_tokens": {
          "type": "array",
          "minItems": 15,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1},
          "allOf": [
            {"contains": {"const": "<|bos|>"}},
            {"contains": {"const": "<|eos|>"}},
            {"contains": {"const": "<|pad|>"}},
            {"contains": {"const": "<|system|>"}},
            {"contains": {"const": "<|user|>"}},
            {"contains": {"const": "<|assistant|>"}},
            {"contains": {"const": "<|tool|>"}},
            {"contains": {"const": "<|tool_result|>"}},
            {"contains": {"const": "<|state|>"}},
            {"contains": {"const": "<|action|>"}},
            {"contains": {"const": "<|evidence|>"}},
            {"contains": {"const": "<|policy|>"}},
            {"contains": {"const": "<|repo|>"}},
            {"contains": {"const": "<|file|>"}},
            {"contains": {"const": "<|diff|>"}}
          ]
        }
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "uri",
        "source_type",
        "synthetic",
        "license",
        "pii",
        "secrets",
        "dedup",
        "content_hash"
      ],
      "properties": {
        "source_id": {"type": "string", "minLength": 1},
        "uri": {"type": "string", "minLength": 1},
        "local_path": {"type": "string", "minLength": 1},
        "source_type": {
          "enum": ["code", "documentation", "structured_text", "mixed", "synthetic"]
        },
        "synthetic": {"type": "boolean"},
        "license": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "spdx_id", "evidence_uri", "reviewed_by"],
          "properties": {
            "status": {"const": "approved"},
            "spdx_id": {"type": ["string", "null"]},
            "evidence_uri": {"type": "string", "minLength": 1},
            "reviewed_by": {"type": "string", "minLength": 1}
          }
        },
        "pii": {"$ref": "#/$defs/safetyGate"},
        "secrets": {"$ref": "#/$defs/safetyGate"},
        "dedup": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "exact", "near_duplicate", "tool_version"],
          "properties": {
            "status": {"const": "complete"},
            "exact": {"const": "sha256"},
            "near_duplicate": {"type": "string", "minLength": 1},
            "tool_version": {"type": "string", "minLength": 1}
          }
        },
        "content_hash": {
          "type": "object",
          "additionalProperties": false,
          "required": ["algorithm", "value"],
          "properties": {
            "algorithm": {"const": "sha256"},
            "value": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
          }
        }
      }
    },
    "safetyGate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "scanner", "evidence_uri"],
      "properties": {
        "status": {"enum": ["clear", "sanitized"]},
        "scanner": {"type": "string", "minLength": 1},
        "evidence_uri": {"type": "string", "minLength": 1}
      }
    }
  }
}
